# =============================================================
# JobTrackr — Environment Variables
# =============================================================
# Copy this file to .env.local and fill in values for self-hosting.
# When running on Lovable Cloud these are set automatically.

# ── Required: Supabase credentials ──────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ── AI Provider (choose ONE) ────────────────────────────────
# All edge functions use the same key/URL/model.
# The helper checks OPENAI_API_KEY first; if unset it falls
# back to LOVABLE_API_KEY (auto-configured on Lovable Cloud).

# Option A — OpenAI (default)
# OPENAI_API_KEY=sk-...
# AI_BASE_URL=https://api.openai.com          # default
# AI_MODEL=gpt-4o-mini                         # default

# Option B — Google AI Studio (OpenAI-compatible endpoint)
# OPENAI_API_KEY=your-google-ai-key
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# AI_MODEL=gemini-2.0-flash

# Option C — Other OpenAI-compatible (Together, Groq, Ollama…)
# OPENAI_API_KEY=your-key
# AI_BASE_URL=https://api.together.xyz/v1
# AI_MODEL=meta-llama/Llama-3-70b-chat-hf

# ── Optional ────────────────────────────────────────────────
# Enables real job-board scraping via Firecrawl (https://firecrawl.dev)
# FIRECRAWL_API_KEY=fc-...
